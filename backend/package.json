{
  "name": "resume-builder-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS='--dns-result-order=ipv4first' tsx watch src/index.ts",
    "build": "tsc",
    "start": "NODE_OPTIONS='--dns-result-order=ipv4first' node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "NODE_OPTIONS='--dns-result-order=ipv4first' prisma migrate dev",
    "db:push": "NODE_OPTIONS='--dns-result-order=ipv4first' prisma db push",
    "db:studio": "NODE_OPTIONS='--dns-result-order=ipv4first' prisma studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.8.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.73.0",
    "pdf-parse": "^1.1.1",
    "puppeteer": "^23.0.0",
    "stripe": "^17.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
